# SPDX-License-Identifier: LGPL-2.1-or-later

[Transfer]
ProtectVersion=%A
Verify=false

[Source]
Type=url-file
Path=https://github.com/albertescanes/particulaos/releases/download/sysupdate/
MatchPattern=%M_@v_%a.usr-%a.@u.raw.xz

[Target]
Type=partition
Path=auto
MatchPattern=%M_@v
MatchPartitionType=usr
PartitionFlags=0
ReadOnly=1
